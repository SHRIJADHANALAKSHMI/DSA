// No special imports needed
// We are using basic arrays only

class Solution {

    public int[] smallerNumbersThanCurrent(int[] nums) {

        // Create a frequency array of size 101
        // Because constraint says:
        //becz 0 <= nums[i] <= 100
        //so we use freq
        int[] freq = new int[101];

        // Step 1: Count how many times each number appears
        // Example: if nums = [8,1,2,2,3]
        // freq[2] will become 2
        for (int num : nums) {
            freq[num]++;
        }

        // Step 2: Convert frequency array into prefix sum array
        // After this:
        // freq[i] will store how many numbers are <= i
        for (int i = 1; i < 101; i++) {
            freq[i] += freq[i - 1];
        }

        // Create result array of same size as input
        int[] result = new int[nums.length];

        // Step 3: For each number in nums
        // Find how many numbers are smaller than it
        for (int i = 0; i < nums.length; i++) {

            // If number is 0
            // There are no smaller numbers
            if (nums[i] == 0) {
                result[i] = 0;
            } else {
                // freq[nums[i] - 1] gives
                // count of numbers strictly smaller than nums[i]
                result[i] = freq[nums[i] - 1];
            }
        }

        // Return final result array
        return result;
    }
}