import java.util.Arrays;
import java.util.Comparator;
class Solution {
    public int[] sortByBits(int[] arr) {
        // Convert int[] to Integer[] to use custom Comparator with Arrays.sort
        Integer[] nums = new Integer[arr.length];
        for (int i = 0; i < arr.length; i++) {
            nums[i] = arr[i];
        }

        Arrays.sort(nums, new Comparator<Integer>() {
            @Override
            public int compare(Integer num1, Integer num2) {
                int bitCount1 = Integer.bitCount(num1);
                int bitCount2 = Integer.bitCount(num2);

                if (bitCount1 != bitCount2) {
                    return bitCount1 - bitCount2; // Sort by bit count ascending
                } else {
                    return num1 - num2; // Sort by value ascending
                }
            }
        });

        // Convert back to int[]
        for (int i = 0; i < arr.length; i++) {
            arr[i] = nums[i];
        }
        return arr;
    }
}
